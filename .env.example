# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ─── Banco de dados principal ─────────────────────────────────────────────────
DB_PASSWORD=vigia

# ─── Banco de dados facial ────────────────────────────────────────────────────
FACE_DB_PASSWORD=face

# ─── API ──────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# ─── Servidor facial ─────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
FACE_PLATFORM_SERVICE_TOKEN=change-this-face-platform-service-token
# Gere com: openssl rand -hex 32
FACE_PLATFORM_ENCRYPTION_KEY=change-this-to-a-long-random-face-platform-key

# ─── Gateway de câmeras ───────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
CAMERA_GATEWAY_SERVICE_TOKEN=change-this-camera-gateway-service-token

# ─── Vídeo ao vivo: gateway desktop -> MediaMTX ──────────────────────────────
# Token usado pelo gateway desktop para autenticar a publicação RTMPS contínua.
# Gere com: openssl rand -hex 24
CAMERA_PUBLISH_TOKEN=change-this-camera-publish-token

# Host/porta do ingest RTMPS. O PC da escola conecta de saída nesta porta cifrada.
MEDIA_INGEST_SCHEME=rtmps
MEDIA_INGEST_HOST=vigiaescolar.com.br
MEDIA_INGEST_PORT=1936

# Endpoint HLS interno consumido pela API para entregar vídeo autenticado ao painel.
MEDIA_INTERNAL_HLS_URL=http://mediamtx:8888

# ─── WhatsApp (opcional) ──────────────────────────────────────────────────────
WHATSAPP_WEBHOOK_URL=
